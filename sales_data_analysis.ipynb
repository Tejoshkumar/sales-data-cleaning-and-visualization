from google.colab import files
uploaded = files.upload()

import pandas as pd
import matplotlib.pyplot as plt

# reading the dataset
df = pd.read_csv('sales.csv')

print("Dataset preview")
print(df.head())

# checking missing values
print("\nMissing values in the dataset")
print(df.isnull().sum())

# filling missing values
df["Age"].fillna(df["Age"].mean(), inplace=True)
df["City"].fillna(df["City"].mode()[0], inplace=True)
df.fillna(0, inplace=True)

# converting some columns to integer
df[["Age","Quantity","Price"]] = df[["Age","Quantity","Price"]].astype(int)

# checking duplicate rows
print("\nNumber of duplicate rows:", df.duplicated().sum())

# removing duplicates
df.drop_duplicates(inplace=True)

print("\nCleaned dataset")
print(df.head())

# analysis part
print("\nAnalysis of data")

# creating total sales column
df["Total_Sales"] = df["Price"] * df["Quantity"]

print("\nSales by product category")
print(df.groupby("Product_Category")["Total_Sales"].sum())

print("\nPayment method usage")
print(df["Payment_Method"].value_counts())

print("\nOrders by city")
print(df["City"].value_counts())

print("\nAverage age:", int(df["Age"].mean()))
print("Total sales:", df["Total_Sales"].sum())
print("Maximum sale:", df["Total_Sales"].max())

# visualization
print("\nCreating graphs")

df.groupby("Product_Category")["Total_Sales"].sum().plot(kind="bar")
plt.title("Sales by category")
plt.xlabel("Product Category")
plt.ylabel("Total Sales")
plt.show()

df["Payment_Method"].value_counts().plot(kind="pie", autopct="%1.1f%%")
plt.title("Payment method distribution")
plt.ylabel("")
plt.show()

df["Age"].plot(kind="hist", bins=10)
plt.title("Age distribution")
plt.xlabel("Age")
plt.ylabel("Frequency")
plt.show()
